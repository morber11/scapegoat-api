GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

APP_ENV=development          # development / production
PROVIDER=gemini              # extend app/api/dependencies.py to add more
REQUEST_TIMEOUT_SECONDS=30
ALLOWED_ORIGINS=            # comma-separated list of permitted CORS origins (empty=>no origins, * allowed in development)
